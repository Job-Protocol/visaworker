# Client — public config, safe to expose to the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Server-only (never expose to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte hex, generate with: openssl rand -hex 32
# Rotating this WITHOUT re-encrypting existing rows will orphan every
# user's stored Anthropic key. Back it up in a secret manager.
BYOK_ENCRYPTION_KEY=

# Optional — used by the demo route only. Match the vault secret named
# `demo_reset_secret` in your Supabase project.
DEMO_RESET_SECRET=

# Optional — the shared public demo account (/demo). Sign-in happens
# server-side, so the password never ships to the browser. DEMO_USER_EMAIL
# defaults to demo@visaworker.ai. DEMO_USER_PASSWORD must match the value
# hashed into auth.users for that account (see the demo-seed migration).
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
