# Client — auto-populated by Lovable / local dev
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Server-only (never expose to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte hex, generate with: openssl rand -hex 32
# Rotating this WITHOUT re-encrypting existing rows will orphan every
# user's stored Anthropic key. Back it up in a secret manager.
BYOK_ENCRYPTION_KEY=

# Optional — used by the demo route only. Match the vault secret named
# `demo_reset_secret` in your Supabase project.
DEMO_RESET_SECRET=
